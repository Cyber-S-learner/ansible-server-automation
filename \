---
  - name: Deploy Website Using Jinja2 Template
    hosts: web
    become: yes


    vars:
      company_name: DevOps Lab

    tasks:
      - name: Deploy Template
        template:
          src: ~/ansible-project/templates/index.html.j2
          dest: /var/www/html/index.html
        notify: Restart Nginx


    handlers: 
        - name: Restart Nginx
          service:
            name: nginx
            state: restarted
